        setFormData({
          Name: "", NumberPhone: "", Email: "", Age: "", ParentsName: "", ParentsPhone: "",
          Program: "", State: ""
        });
      } else {
        setStatus("error");
        setErrorMessage(result.message || "Something went wrong");
      }
    } catch (err) {
